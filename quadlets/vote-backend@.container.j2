# quadlets/vote-backend@.container.j2
# Podman quadlet template for the vote-backend application.
# The instance name (%i) is the version string, e.g. vote-backend@0.1.0.service
# Install to /etc/containers/systemd/vote-backend@.container
#
# Build the image first (after cmake configure generates version.txt):
#   podman build -f Containerfile -t vote-backend:"$(cat version.txt)" .
#
# The database must be running before this container starts.
# Config is loaded from /etc/vote/config.json inside the container.

[Container]
ContainerName=vote-backend
Image=localhost/vote-backend:%i
Network=vote.network
# Publish the host port only when no nginx reverse proxy is deployed (the
# ephemeral/test setup). With nginx (persistent deployment) the backend is
# reached solely through the podman bridge network, so the port stays
# unpublished and clients cannot bypass nginx to hit the backend directly.
{% if not (vote_backend_postgres_persistent | default(false)) %}PublishPort=8848:8848
{% endif %}
Volume=%h/.config/vote-backend:/etc/vote

[Service]
Restart=on-failure

[Unit]
After=drogon-postgres.service
Requires=drogon-postgres.service

[Install]
